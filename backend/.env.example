# ===== Server =====
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
SESSION_SECRET=replace-with-long-random-string
JWT_SECRET=replace-with-another-long-random-string

# ===== MongoDB =====
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bsp?appName=Cluster0

# ===== Meta Graph API =====
META_GRAPH_VERSION=v23.0
META_GRAPH_BASE=https://graph.facebook.com

# ===== BSP Meta App credentials =====
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_CONFIG_ID=your_login_for_business_config_id
META_REDIRECT_URI=https://your-backend.onrender.com/api/auth/facebook/callback

# ===== Admin panel =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# ===== Display name review =====
FORCE_DISPLAY_NAME_REVIEW=true
DISPLAY_NAME_SUFFIX=
